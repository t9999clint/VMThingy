######
## Start of Main function
######

# Detect VMware Workstation
if command_exists vmrun; then
    VMMode="VMWARE"
else
    VMMode="KVM"
fi


#Pull the installed VMs
if [ "$VMMode" == "VMWARE" ]; then
    REQUIRED_PROGRAMS+=(vmrun)
    get_vmware_vms

elif [ "$VMMode" == "KVM" ]; then
    REQUIRED_PROGRAMS+=("${REQUIRED_KVM_PROGRAMS[@]}")
    get_kvm_vms

  #also check for required KVM programs
  if command_exists virt-manager &&
     command_exists krdc
  then
    USE_FLATPAK=false
  fi
elif command_exists krdc
then
    USE_FLATPAK=false
fi

# checks if flatpak is needed
$USE_FLATPAK && REQUIRED_PROGRAMS+=(flatpak)

# check for required programs
required_cmd "${REQUIRED_PROGRAMS[@]}" || exit 1

# check for required flathub apps if local versions aren't availible
if $USE_FLATPAK;
then
  FLATHUB_APPS=()

  #if KVM then check for virtmanager
  CurrentApp="org.virt_manager.virt-manager"
  if [[ "$VMMode" == "KVM" ]] &&
    ! command_exists virt-manager &&
    ! flatpak_app_exists "$CurrentApp"
  then
    FLATHUB_APPS+=("$CurrentApp")
  fi

  #only krdc is supported for now. Might add a fallback to xFreeRDP or something later
  CurrentApp="org.kde.krdc"
  if ! command_exists krdc &&
     ! flatpak_app_exists "$CurrentApp"
  then
    FLATHUB_APPS+=("$CurrentApp")
  fi

  #try to install missing apps
  if [ -n "$FLATHUB_APPS" ];
  then
    install_flatpak_apps "${FLATHUB_APPS[@]}" || exit 1
  fi
fi

#display a list of VMs to choose from if there are more than one.
if select_windows_vm; then
  i="$SELECTED_VM_INDEX"

  #if the state is not running, Start the VM
  if ! [[ "${ALL_STATES[$i]}" =~ "unning" ]]; then

      if [ "$VMMode" == "KVM" ]; then
          virsh -c ${ALL_URIS[$i]} start ${ALL_VMS[$i]} 2>/dev/null
          virsh -c ${ALL_URIS[$i]} dompmwakeup ${ALL_VMS[$i]} 2>/dev/null

      elif [ "$VMMode" == "VMWARE" ]; then
          vmrun start "${ALL_URIS[$i]}" nogui 2>/dev/null
      fi
  fi

#if no VMs detected, start virtmanager so user can make one
elif (( ${#ALL_VMS[@]} == 0 )); then
  if $USE_FLATPAK
  then
    flatpak run org.virt_manager.virt-manager
  else
    virt-manager
  fi

#assume user canceled and quit program
else
  exit
fi

#if a VM was selected and started, then wait for
if [ -n $SELECTED_VM_INDEX ]; then

  #wait for VM to become ready then connect to ip using krdc
  if wait_for_vm_ready "${ALL_VMS[$i]}" "${ALL_URIS[$i]}"; then

      echo "Connecting to $VM_READY_IP"
      if $USE_FLATPAK; then
        flatpak run org.kde.krdc "rdp://$VMUSER@$VM_READY_IP" 2>/dev/null
      else
        krdc "rdp://$VMUSER@$VM_READY_IP" 2>/dev/null
      fi
  fi
fi

